{
  "name": "mednutri",
  "version": "2.0.0",
  "description": "MedNutri — AI-powered clinical nutrition platform (Next.js + Streamlit)",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"NEXT,STREAMLIT\" --prefix-colors \"cyan,magenta\" --kill-others-on-fail \"npm run frontend\" \"npm run backend\"",
    "frontend": "cd frontend && npm run dev",
    "backend": "cd backend && streamlit run app.py --server.port 8501",
    "install:frontend": "cd frontend && npm install",
    "setup": "npm run install:frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
